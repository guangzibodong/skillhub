# Public URLs
NEXT_PUBLIC_APP_URL=https://app.useskillhub.com
NEXT_PUBLIC_API_URL=https://api.useskillhub.com

# Runtime
SKILLHUB_ENV=production

# Database
# Generate a long random password before deploying.
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgres://skillhub:replace-with-a-long-random-password@postgres:5432/skillhub

# Cache / queue
REDIS_URL=redis://redis:6379

# Auth and secrets
SESSION_SECRET=replace-with-a-long-random-secret
SKILLHUB_OAUTH_STATE_SECRET=replace-with-a-long-random-secret
SKILLHUB_EMAIL_AUTH_SECRET=replace-with-a-long-random-secret
SKILLHUB_EMAIL_AUTH_DEBUG_CODES=false
SKILLHUB_API_KEY_SALT=replace-with-a-long-random-secret
SKILLHUB_ADMIN_TOKEN=replace-with-a-long-random-admin-token
SKILLHUB_AUTH_CALLBACK_BASE_URL=https://api.useskillhub.com
SKILLHUB_AUTH_COOKIE_DOMAIN=.useskillhub.com
SKILLHUB_GOOGLE_CLIENT_ID=
SKILLHUB_GOOGLE_CLIENT_SECRET=
SKILLHUB_GITHUB_CLIENT_ID=
SKILLHUB_GITHUB_CLIENT_SECRET=
SKILLHUB_EMAIL_PROVIDER=resend
SKILLHUB_EMAIL_FROM=no-reply@useskillhub.com
RESEND_API_KEY=
SKILLHUB_WEBHOOK_TIMEOUT_MS=8000
SKILLHUB_WEBHOOK_MAX_ATTEMPTS=8

# OAuth callback URLs to register with providers:
# Google: https://api.useskillhub.com/v1/auth/oauth/google/callback
# GitHub: https://api.useskillhub.com/v1/auth/oauth/github/callback

# Optional AI features
OPENAI_API_KEY=

# Observability
SENTRY_DSN=
POSTHOG_KEY=
