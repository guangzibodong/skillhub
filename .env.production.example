# Public URLs
NEXT_PUBLIC_APP_URL=https://app.useskillhub.com
NEXT_PUBLIC_API_URL=https://api.useskillhub.com

# Runtime
SKILLHUB_ENV=production

# Database
# Generate a long random password before deploying.
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgres://skillhub:replace-with-a-long-random-password@postgres:5432/skillhub

# Cache / queue
REDIS_URL=redis://redis:6379

# Auth and secrets, to be wired in the next milestone.
SESSION_SECRET=replace-with-a-long-random-secret
SKILLHUB_API_KEY_SALT=replace-with-a-long-random-secret

# Optional AI features
OPENAI_API_KEY=

# Observability
SENTRY_DSN=
POSTHOG_KEY=
