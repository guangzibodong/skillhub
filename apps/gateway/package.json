{
  "name": "@useskillhub/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "SkillHub Cloudflare Workers API and agent gateway.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "dev:node": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@useskillhub/schema": "workspace:*",
    "@hono/node-server": "^1.13.8",
    "hono": "^4.6.14",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
