# App
# Single source of truth for local runtime URLs.
# NEXT_PUBLIC_* is used by the browser. SKILLHUB_SERVER_API_URL is used by local Next.js server code.
# For Docker Compose local: web=http://localhost:3100, public API=http://localhost:18787. Docker internal service wiring stays in docker-compose.1panel.yml.
SKILLHUB_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3100
NEXT_PUBLIC_API_URL=http://localhost:18787
SKILLHUB_SERVER_API_URL=http://localhost:18787
SKILLHUB_DISABLE_PUBLIC_SIGNUP=false

# Database, root secrets, and recovery bootstrap
# Keep these in the server environment or a secret manager.
POSTGRES_PASSWORD=replace-with-a-long-random-password
SKILLHUB_ADMIN_TOKEN=replace-with-a-long-random-admin-token
SKILLHUB_API_KEY_SALT=replace-with-a-long-random-api-key-salt
SKILLHUB_CONFIG_ENCRYPTION_SECRET=replace-with-a-stable-32-plus-character-secret
# Legacy compatibility only. Prefer SKILLHUB_CONFIG_ENCRYPTION_SECRET.
SKILLHUB_AGENT_KEY_ENCRYPTION_SECRET=

# Auth root secrets
SESSION_SECRET=replace-with-a-long-random-session-secret
SKILLHUB_OAUTH_STATE_SECRET=replace-with-a-long-random-oauth-state-secret
SKILLHUB_EMAIL_AUTH_SECRET=replace-with-a-long-random-email-auth-secret
SKILLHUB_EMAIL_AUTH_DEBUG_CODES=true
SKILLHUB_AUTH_CALLBACK_BASE_URL=http://localhost:18787
SKILLHUB_AUTH_COOKIE_DOMAIN=

# Admin-configured providers and runtime settings
# Production OAuth, email, Stripe, PayPal, webhook delivery, payout thresholds,
# launch gates, public signup policy, and agent model keys are configured in /admin.
# The variables below are migration/bootstrap fallbacks only.
SKILLHUB_GOOGLE_CLIENT_ID=
SKILLHUB_GOOGLE_CLIENT_SECRET=
SKILLHUB_GITHUB_CLIENT_ID=
SKILLHUB_GITHUB_CLIENT_SECRET=
SKILLHUB_EMAIL_PROVIDER=
SKILLHUB_EMAIL_FROM=
RESEND_API_KEY=
SKILLHUB_SMTP_HOST=
SKILLHUB_SMTP_PORT=465
SKILLHUB_SMTP_SECURE=true
SKILLHUB_SMTP_USER=
SKILLHUB_SMTP_PASSWORD=
SKILLHUB_WEBHOOK_TIMEOUT_MS=8000
SKILLHUB_WEBHOOK_MAX_ATTEMPTS=8

# Finance defaults
SKILLHUB_MIN_PAYOUT_CENTS=5000
SKILLHUB_PAYOUT_REVIEW_THRESHOLD_CENTS=100000

# Stripe commerce
# Use Stripe test mode keys locally and in CI; switch to live keys only for production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
SKILLHUB_STRIPE_SUCCESS_URL=http://localhost:3100/developer/billing?checkout=success
SKILLHUB_STRIPE_CANCEL_URL=http://localhost:3100/marketplace?checkout=canceled
SKILLHUB_STRIPE_RETURN_URL=http://localhost:3100/publisher?stripe_connect=return
SKILLHUB_STRIPE_REFRESH_URL=http://localhost:3100/publisher?stripe_connect=refresh

# PayPal commerce
# Use PayPal sandbox locally and in CI; switch to live only for production.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=
SKILLHUB_PAYPAL_RETURN_URL=http://localhost:3100/checkout/paypal/return
SKILLHUB_PAYPAL_CANCEL_URL=http://localhost:3100/marketplace?checkout=paypal-canceled

# Launch credibility defaults
SKILLHUB_LAUNCH_MIN_VERIFIED_SKILLS=5
SKILLHUB_LAUNCH_MIN_ACTIVE_PUBLISHERS=2
SKILLHUB_LAUNCH_MIN_ACTIVE_PROJECTS=3
SKILLHUB_LAUNCH_MIN_SUCCESSFUL_INVOCATIONS=20
SKILLHUB_LAUNCH_MIN_PUBLISHED_FEEDBACK=5

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
SKILLHUB_R2_BUCKET=skillhub-packages

# Agent prompt assistant
# Model provider keys are configured in /admin and encrypted with SKILLHUB_CONFIG_ENCRYPTION_SECRET.

# Observability
SENTRY_DSN=
POSTHOG_KEY=
