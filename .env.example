# App
SKILLHUB_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787
SKILLHUB_DISABLE_PUBLIC_SIGNUP=false

# Database and service bootstrap
POSTGRES_PASSWORD=replace-with-a-long-random-password
SKILLHUB_ADMIN_TOKEN=replace-with-a-long-random-admin-token
SKILLHUB_API_KEY_SALT=replace-with-a-long-random-api-key-salt

# Auth
SESSION_SECRET=replace-with-a-long-random-session-secret
SKILLHUB_OAUTH_STATE_SECRET=replace-with-a-long-random-oauth-state-secret
SKILLHUB_EMAIL_AUTH_SECRET=replace-with-a-long-random-email-auth-secret
SKILLHUB_EMAIL_AUTH_DEBUG_CODES=true
SKILLHUB_AUTH_CALLBACK_BASE_URL=http://localhost:8787
SKILLHUB_AUTH_COOKIE_DOMAIN=
SKILLHUB_GOOGLE_CLIENT_ID=
SKILLHUB_GOOGLE_CLIENT_SECRET=
SKILLHUB_GITHUB_CLIENT_ID=
SKILLHUB_GITHUB_CLIENT_SECRET=
SKILLHUB_EMAIL_PROVIDER=
SKILLHUB_EMAIL_FROM=
RESEND_API_KEY=
SKILLHUB_SMTP_HOST=
SKILLHUB_SMTP_PORT=465
SKILLHUB_SMTP_SECURE=true
SKILLHUB_SMTP_USER=
SKILLHUB_SMTP_PASSWORD=
SKILLHUB_WEBHOOK_TIMEOUT_MS=8000
SKILLHUB_WEBHOOK_MAX_ATTEMPTS=8

# Finance defaults
SKILLHUB_MIN_PAYOUT_CENTS=5000
SKILLHUB_PAYOUT_REVIEW_THRESHOLD_CENTS=100000

# Launch credibility defaults
SKILLHUB_LAUNCH_MIN_VERIFIED_SKILLS=5
SKILLHUB_LAUNCH_MIN_ACTIVE_PUBLISHERS=2
SKILLHUB_LAUNCH_MIN_ACTIVE_PROJECTS=3
SKILLHUB_LAUNCH_MIN_SUCCESSFUL_INVOCATIONS=20
SKILLHUB_LAUNCH_MIN_PUBLISHED_FEEDBACK=5

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
SKILLHUB_R2_BUCKET=skillhub-packages

# Optional AI features
OPENAI_API_KEY=

# Observability
SENTRY_DSN=
POSTHOG_KEY=
