{
  "name": "skillhub",
  "private": true,
  "version": "0.1.0",
  "description": "Universal skills for AI agents.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "smoke": "node scripts/qa-smoke.mjs",
    "smoke:p0": "node scripts/qa-p0-release-suite.mjs",
    "smoke:p0:admin": "node scripts/qa-p0-admin-operations-smoke.mjs",
    "smoke:p0:demo": "node scripts/qa-p0-demo-chain-smoke.mjs",
    "smoke:p0:developer": "node scripts/qa-p0-developer-handoff-smoke.mjs",
    "smoke:p0:publish": "node scripts/qa-p0-publish-handoff-smoke.mjs",
    "smoke:prod": "node scripts/qa-p0-release-suite.mjs --prod --skip-admin --timeout-ms 30000",
    "qa:public": "node scripts/public-launch-readiness.mjs",
    "qa:anonymous": "node scripts/qa-public-anonymous.mjs",
    "qa:acceptance-team": "node scripts/qa-acceptance-team.mjs",
    "acceptance:team": "node scripts/create-acceptance-team.mjs",
    "test:acceptance-team-report": "node --test scripts/qa-acceptance-team-report.test.mjs",
    "test:skill-availability": "node --test scripts/skill-availability.test.mjs"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
