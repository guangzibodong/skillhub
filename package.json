{
  "name": "skillhub",
  "private": true,
  "version": "0.1.0",
  "description": "Universal skills for AI agents.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "smoke": "node scripts/qa-smoke.mjs",
    "smoke:p0:developer": "node scripts/qa-p0-developer-handoff-smoke.mjs",
    "smoke:p0:publish": "node scripts/qa-p0-publish-handoff-smoke.mjs",
    "smoke:prod": "node scripts/qa-smoke.mjs --api-url https://api.useskillhub.com --app-url https://app.useskillhub.com"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
